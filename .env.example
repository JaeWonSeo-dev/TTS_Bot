DISCORD_TOKEN=put-your-discord-bot-token-here
COMMAND_PREFIX=!
TTS_ENGINE=gpt_sovits
TTS_VOICE=sample_speaker
GPT_SOVITS_API_URL=http://127.0.0.1:9880/tts
GPT_SOVITS_DEFAULT_PROMPT_LANGUAGE=ko
GPT_SOVITS_DEFAULT_TEXT_LANGUAGE=ko
GPT_SOVITS_MAX_CHUNK_LENGTH=120
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_USE_CUDA=true
XTTS_DEFAULT_LANGUAGE=ko
XTTS_MAX_CHUNK_LENGTH=180
FFMPEG_PATH=ffmpeg
MAX_TTS_LENGTH=300
DEBUG_LOG=true
TTS_DATA_DIR=data
TTS_SAMPLES_DIR=voice_samples
